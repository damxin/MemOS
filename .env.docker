# MemOS Docker Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# Base Configuration
# ============================================================================
TZ=Asia/Shanghai
MEMOS_ENV=production
MEMOS_LOG_LEVEL=info

# Data paths (inside container)
MOS_CUBE_PATH=/app/data/cube
MEMOS_BASE_PATH=/app/data

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_USER=memos
POSTGRES_PASSWORD=2BrnwJTPjtd4iDEQ
POSTGRES_DB=memos
POSTGRES_PORT=24432

# Vector DB settings (used by MemOS)
MEMOS_VEC_DB_BACKEND=pgvector
MEMOS_VEC_DB_HOST=postgres
MEMOS_VEC_DB_PORT=5432
MEMOS_VEC_DB_USER=memos
MEMOS_VEC_DB_PASSWORD=2BrnwJTPjtd4iDEQ
MEMOS_VEC_DB_DATABASE=memos
MEMOS_VEC_DB_COLLECTION=default
MEMOS_VEC_DB_VECTOR_DIMENSION=768
MEMOS_VEC_DB_DISTANCE_METRIC=cosine

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=
REDIS_PORT=6379

MEMOS_REDIS_ENABLED=true
MEMOS_REDIS_HOST=redis
MEMOS_REDIS_PORT=6379
MEMOS_REDIS_PASSWORD=

# ============================================================================
# Server Configuration
# ============================================================================
MEMOS_HOST=0.0.0.0
MEMOS_PORT=8080

# Security (generate strong secrets in production)
MEMOS_SECRET_KEY=change-me-in-production-secret-key
MEMOS_JWT_SECRET=change-me-in-production-jwt-secret

# ============================================================================
# LLM Configuration (External APIs)
# ============================================================================
MOS_CHAT_MODEL=silkqwen3.5-4b
MOS_CHAT_MODEL_PROVIDER=openai
MOS_CHAT_TEMPERATURE=0.8
MOS_MAX_TOKENS=2048
MOS_TOP_P=0.9
MOS_TOP_K=50

# API Keys (replace with your actual keys)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

MEMRADER_MODEL=silkqwen3.5-4b
MEMRADER_API_KEY=your-memreader-api-key
MEMRADER_API_BASE=https://api.openai.com/v1

# ============================================================================
# Embedding & Reranker Configuration
# ============================================================================
EMBEDDING_DIMENSION=1024
MOS_EMBEDDER_BACKEND=universal_api
MOS_EMBEDDER_PROVIDER=openai
MOS_EMBEDDER_MODEL=BAAI/bge-m3
MOS_EMBEDDER_API_BASE=https://api.siliconflow.cn/v1
MOS_EMBEDDER_API_KEY=your-embedding-api-key

MOS_RERANKER_BACKEND=http_bge
MOS_RERANKER_URL=https://api.siliconflow.cn/v1
MOS_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ============================================================================
# Feature Toggles
# ============================================================================
MOS_ENABLE_DEFAULT_CUBE_CONFIG=true
MOS_ENABLE_REORGANIZE=false
ASYNC_MODE=sync

ENABLE_INTERNET=false
ENABLE_PREFERENCE_MEMORY=true
PREFERENCE_ADDER_MODE=fast

# Text memory type: general_text | tree_text
MOS_TEXT_MEM_TYPE=general_text

# Reader chunking
MEM_READER_BACKEND=simple_struct
MEM_READER_CHAT_CHUNK_TYPE=default
MEM_READER_CHAT_CHUNK_TOKEN_SIZE=1600
MEM_READER_CHAT_CHUNK_SESS_SIZE=10
