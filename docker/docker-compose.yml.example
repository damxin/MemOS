name: memos-dev

services:
  memos:
    container_name: memos-api-docker
    build:
      context: ..
      dockerfile: docker/Dockerfile
    ports:
      - "8000:8000"
    env_file:
      - ../.env
    depends_on:
      neo4j:
        condition: service_healthy
    environment:
      - PYTHONPATH=/app/src
      - HF_ENDPOINT=https://hf-mirror.com
      - NEO4J_URI=bolt://neo4j-docker:7687
      # PostgreSQL + pgvector (external container)
      - VECTOR_DB_BACKEND=pgvector
      - PGVECTOR_HOST=postgres18v
      - PGVECTOR_PORT=5432
      - PGVECTOR_DATABASE=memos
      - PGVECTOR_USER=memos
      - PGVECTOR_PASSWORD=${PGVECTOR_PASSWORD:-your_pgvector_password_here}
      - PGVECTOR_DIMENSION=1024
      # Disable RabbitMQ (set to true to enable)
      - MEMOS_ENABLE_RABBITMQ=false
    volumes:
      - ../src:/app/src
      - .:/app/docker
    networks:
      - 1panel-network

  neo4j:
    image: neo4j:5.26.4
    container_name: neo4j-docker
    ports:
      - "7474:7474"   # HTTP
      - "7687:7687"   # Bolt
    healthcheck:
      test: wget http://localhost:7474 || exit 1
      interval: 1s
      timeout: 10s
      retries: 20
      start_period: 3s
    environment:
      NEO4J_ACCEPT_LICENSE_AGREEMENT: "yes"
      NEO4J_AUTH: "neo4j/12345678"
    volumes:
      - neo4j_data:/data
      - neo4j_logs:/logs
    networks:
      - 1panel-network

volumes:
  neo4j_data:
  neo4j_logs:

networks:
  1panel-network:
    external: true
    name: 1panel-network
